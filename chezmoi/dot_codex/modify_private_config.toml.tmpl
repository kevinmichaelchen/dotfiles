#!/usr/bin/env bash
# Manage only the Executor MCP stanzas in ~/.codex/config.toml.

set -euo pipefail

tmp="$(mktemp "${TMPDIR:-/tmp}/codex-config.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
cat >"$tmp"

python3 - "$tmp" <<'PY'
import json
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text()

cloud_authorization = json.dumps('Bearer {{ env "EXECUTOR_CLOUD_API_KEY" }}')
desktop_authorization = json.dumps('Bearer {{ env "EXECUTOR_DESKTOP_MCP_TOKEN" }}')

block = f'''[mcp_servers.executor]
type = "http"
url = "https://executor.sh/kevin-chen-s-organization/mcp"

[mcp_servers.executor.http_headers]
Authorization = {cloud_authorization}

[mcp_servers.executor-desktop]
type = "http"
url = "http://localhost:4789/mcp"

[mcp_servers.executor-desktop.http_headers]
Authorization = {desktop_authorization}
'''

pattern = re.compile(
    r'(?ms)^\[mcp_servers\.(?:executor|executor-desktop|executor-cloud)(?:\.[^\]]+)?\]\n.*?(?=^\[|\Z)'
)
text = pattern.sub("", text).rstrip()
text = text + "\n\n" + block if text else block
print(text.rstrip() + "\n", end="")
PY
