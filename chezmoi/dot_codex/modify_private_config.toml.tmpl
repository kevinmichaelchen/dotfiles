#!/usr/bin/env bash
# Manage only the Executor MCP stanza in ~/.codex/config.toml.
# Preserve Codex runtime state such as project trust, model selections, and NUX flags.

set -euo pipefail

tmp="$(mktemp "${TMPDIR:-/tmp}/codex-config.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
cat >"$tmp"

python3 - "$tmp" <<'PY'
import json
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text()

desktop_authorization = json.dumps(
    'Bearer {{ onepasswordRead "op://Software/Executor Desktop MCP/password" }}'
)

block = f'''[mcp_servers.executor]
type = "http"
url = "https://executor.sh/kevin-chen-s-organization/mcp"

[mcp_servers.executor-desktop]
type = "http"
url = "http://localhost:4789/mcp"

  [mcp_servers.executor-desktop.http_headers]
  Authorization = {desktop_authorization}
'''

pattern = re.compile(
    r'(?ms)^\[mcp_servers\.(?:executor|executor-desktop|executor-cloud)(?:\.[^\]]+)?\]\n.*?(?=^\[|\Z)'
)

if text.strip():
    text = pattern.sub("", text).rstrip()
    text += "\n\n" + block
else:
    text = block

if not text.endswith("\n"):
    text += "\n"

print(text, end="")
PY
