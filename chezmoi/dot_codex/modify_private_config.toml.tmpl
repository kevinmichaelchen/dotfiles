#!/usr/bin/env bash
# Manage only the Executor MCP stanzas in ~/.codex/config.toml.

set -euo pipefail

tmp="$(mktemp "${TMPDIR:-/tmp}/codex-config.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
cat >"$tmp"

python3 - "$tmp" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text()

block = '''[mcp_servers.executor]
type = "http"
url = "https://executor.sh/kevin-chen-s-organization/mcp"

[mcp_servers.executor-desktop]
command = "executor"
args = ["mcp"]
'''

pattern = re.compile(
    r'(?ms)^\[mcp_servers\.(?:executor|executor-desktop|executor-cloud)(?:\.[^\]]+)?\]\n.*?(?=^\[|\Z)'
)
text = pattern.sub("", text).rstrip()
text = text + "\n\n" + block if text else block
print(text.rstrip() + "\n", end="")
PY
