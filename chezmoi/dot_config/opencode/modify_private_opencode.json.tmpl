#!/usr/bin/env bash
# Keep only the Executor MCP entries in ~/.config/opencode/opencode.json.

set -euo pipefail

tmp="$(mktemp "${TMPDIR:-/tmp}/opencode-config.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
cat >"$tmp"

python3 - "$tmp" <<'PY'
import json
from pathlib import Path
import sys

path = Path(sys.argv[1])
raw = path.read_text().strip()
data = json.loads(raw) if raw else {"$schema": "https://opencode.ai/config.json"}

data["mcp"] = {
    "executor": {
        "type": "remote",
        "url": "https://executor.sh/kevin-chen-s-organization/mcp",
        "enabled": True,
    },
    "executor-desktop": {
        "type": "local",
        "command": ["executor", "mcp"],
        "enabled": True,
    },
}

print(json.dumps(data, indent=2))
print()
PY
