#!/usr/bin/env bash
# Manage only the Executor MCP entries in ~/.config/opencode/opencode.json.

set -euo pipefail

tmp="$(mktemp "${TMPDIR:-/tmp}/opencode-config.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
cat >"$tmp"

python3 - "$tmp" <<'PY'
import json
from pathlib import Path
import sys

path = Path(sys.argv[1])
raw = path.read_text().strip()
data = json.loads(raw) if raw else {"$schema": "https://opencode.ai/config.json"}

servers = data.setdefault("mcp", {})
for name in ("executor", "executor-desktop", "executor-cloud"):
    servers.pop(name, None)

servers["executor"] = {
    "type": "remote",
    "url": "https://executor.sh/kevin-chen-s-organization/mcp",
    "headers": {"Authorization": 'Bearer {{ env "EXECUTOR_CLOUD_API_KEY" }}'},
    "enabled": True,
}
servers["executor-desktop"] = {
    "type": "remote",
    "url": "http://localhost:4789/mcp",
    "headers": {"Authorization": 'Bearer {{ env "EXECUTOR_DESKTOP_MCP_TOKEN" }}'},
    "enabled": True,
}

print(json.dumps(data, indent=2))
print()
PY
