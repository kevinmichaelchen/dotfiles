#!/bin/sh
# GitHub CLI (gh) aliases
# Shell-agnostic - can be sourced by bash, zsh, etc.

if command -v gh >/dev/null 2>&1; then
  GITHUB_PERSONAL_ACCESS_TOKEN="$(gh auth token 2>/dev/null || true)"
fi

if [ -z "${GITHUB_PERSONAL_ACCESS_TOKEN:-}" ]; then
  export GITHUB_PERSONAL_ACCESS_TOKEN='{{ onepasswordRead "op://Software/GitHub/GitHub Personal Access Token" }}'
else
  export GITHUB_PERSONAL_ACCESS_TOKEN
fi

alias pr-approve='gh pr review --approve'
alias pr-web='gh pr view --web'
alias pr-checkout='gh pr checkout'
alias pr-diff='gh pr diff'
